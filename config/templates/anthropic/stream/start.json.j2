{#- Anthropic stream: opening events (message_start + content_block_start + ping).

    The first content_block_start's `content_block` field is one of:
      - {"type": "text", "text": ""}            (text response)
      - {"type": "tool_use", "id, "name", "input": {}} (tool_use response)

    We detect tool-mode via the request body (json.tools present AND no prior
    tool_result) because `chunk` isn't bound in the context at on_start time
    (it's only bound during per-chunk rendering). This mirrors the same
    detection used by on_stop.
-#}
{%- set is_tool_mode = json.tools and not has_tool_result(messages=json.messages, provider="anthropic") -%}
event: message_start
data: {"type":"message_start","message":{"id":"msg_{{ uuid }}","type":"message","role":"assistant","content":[],"model":"{{ model | default(value='claude-haiku-4-5-20251001') }}","stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":16,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"}}}

event: content_block_start
{% if is_tool_mode -%}
data: {"type":"content_block_start","index":0,"content_block":{"type":"tool_use","id":"toolu_{{ uuid }}","name":"{{ json.tools.0.name | default(value='mock_tool') }}","input":{}}}
{%- else -%}
data: {"type":"content_block_start","index":0,"content_block":{"type":"text","text":""}}
{%- endif %}

event: ping
data: {"type":"ping"}
