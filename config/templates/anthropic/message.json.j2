{#
   Anthropic /v1/messages response template.

   Branches on request fields (order matters):
     - tools present + tool_result already in messages -> plain text synthesis
       (terminates agentic tool-calling loops; otherwise ADK/LangGraph
       would call the mock forever)
     - tools present                                  -> tool_use block
     - default                                        -> text response

   Includes 2025+ fields: cache_creation, service_tier, inference_geo, stop_details.
#}
{%- set has_result = has_tool_result(messages=json.messages, provider="anthropic") -%}
{%- set emit_tool_use = json.tools and not has_result -%}
{
  "id": "msg_{{ uuid }}",
  "type": "message",
  "role": "assistant",
  "model": "{{ model | default(value='claude-haiku-4-5-20251001') }}",
  "content": [
    {% if emit_tool_use %}
    {
      "type": "tool_use",
      "id": "toolu_{{ uuid }}",
      "name": "{{ json.tools.0.name | default(value='mock_tool') }}",
      "input": {},
      "caller": {
        "type": "direct"
      }
    }
    {% elif has_result %}
    {
      "type": "text",
      "text": "Based on the tool results, here is the answer."
    }
    {% else %}
    {
      "type": "text",
      "text": "Anthropic mock response. {{ iso_timestamp() }}"
    }
    {% endif %}
  ],
  {% if emit_tool_use %}
  "stop_reason": "tool_use",
  {% else %}
  "stop_reason": "end_turn",
  {% endif %}
  "stop_sequence": null,
  "stop_details": null,
  "usage": {
    "input_tokens": 16,
    "cache_creation_input_tokens": 0,
    "cache_read_input_tokens": 0,
    "cache_creation": {
      "ephemeral_5m_input_tokens": 0,
      "ephemeral_1h_input_tokens": 0
    },
    "output_tokens": 10,
    "service_tier": "standard",
    "inference_geo": "not_available"
  }
}
