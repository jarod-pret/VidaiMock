{#
   Gemini generateContent response template.

   Branches on request fields (order matters):
     - tools present + functionResponse already in contents -> plain text
       (terminates agentic tool-calling loops; otherwise ADK would loop)
     - tools present                                       -> functionCall
     - default                                             -> text response

   Includes Gemini 2.5 fields: thoughtsTokenCount, promptTokensDetails,
   modelVersion, responseId.
#}
{%- set has_result = has_tool_result(messages=json.contents, provider="gemini") -%}
{%- set emit_function_call = json.tools and not has_result -%}
{
  "candidates": [
    {
      "content": {
        "parts": [
          {% if emit_function_call %}
          {
            "functionCall": {
              "name": "{{ json.tools.0.functionDeclarations.0.name | default(value='mock_function') }}",
              "args": {}
            }
          }
          {% elif has_result %}
          {
            "text": "Based on the tool results, here is the answer."
          }
          {% else %}
          {
            "text": "Gemini mock response. {{ iso_timestamp() }}"
          }
          {% endif %}
        ],
        "role": "model"
      },
      {% if emit_function_call %}
      "finishReason": "STOP",
      "finishMessage": "Model generated function call(s).",
      {% else %}
      "finishReason": "STOP",
      {% endif %}
      "index": 0,
      "safetyRatings": [
        {
          "category": "HARM_CATEGORY_SEXUALLY_EXPLICIT",
          "probability": "NEGLIGIBLE"
        },
        {
          "category": "HARM_CATEGORY_HATE_SPEECH",
          "probability": "NEGLIGIBLE"
        }
      ]
    }
  ],
  "usageMetadata": {
    "promptTokenCount": 10,
    "candidatesTokenCount": 8,
    "totalTokenCount": 40,
    "promptTokensDetails": [
      {
        "modality": "TEXT",
        "tokenCount": 10
      }
    ],
    "thoughtsTokenCount": 22
  },
  "modelVersion": "gemini-2.5-flash",
  "responseId": "mock-{{ uuid }}"
}
