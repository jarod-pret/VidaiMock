{#- Gemini-shape error envelope.
    Real Gemini errors: {"error":{"code":N,"message":"...","status":"..."}}
    status is a gRPC status name like INVALID_ARGUMENT, NOT_FOUND, UNAUTHENTICATED. -#}
{
  "error": {
    "code": {{ status_code | default(value=500) }},
    "message": "Mock error response (HTTP {{ status_code | default(value=500) }}).",
    "status": {% if status_code == 400 %}"INVALID_ARGUMENT"{% elif status_code == 401 %}"UNAUTHENTICATED"{% elif status_code == 403 %}"PERMISSION_DENIED"{% elif status_code == 404 %}"NOT_FOUND"{% elif status_code == 429 %}"RESOURCE_EXHAUSTED"{% elif status_code == 503 %}"UNAVAILABLE"{% elif status_code >= 500 %}"INTERNAL"{% else %}"INVALID_ARGUMENT"{% endif %}
  }
}
