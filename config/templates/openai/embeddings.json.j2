{
  "object": "list",
  "data": [
    {
      "object": "embedding",
      "index": 0,
      "embedding": [
        {% for i in range(end=1536) %}
        {{ random_float(min=-1.0, max=1.0) }}{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  ],
  "model": "{{ json.model | default(value='text-embedding-3-small') }}",
  "usage": {
    "prompt_tokens": {{ random_int(min=5, max=50) }},
    "total_tokens": {{ random_int(min=5, max=50) }}
  }
}
